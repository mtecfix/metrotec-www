---
layout: base.njk
---

<article class="blog-post">
  <h1>{{ title }}</h1>
  <time datetime="{{ date | dateFormat }}">{{ date | dateFormat }}</time>
  {% if tags %}
  <div class="tags">
    {% for tag in tags %}
    <span class="tag">{{ tag }}</span>
    {% endfor %}
  </div>
  {% endif %}
  
  {{ content | safe }}
</article>

